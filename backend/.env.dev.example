# Cognito Auth (copy to .env.dev and fill in real values)
export AUTH_ENABLED=true
export COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
export COGNITO_CLIENT_ID=your-cognito-client-id
export AWS_REGION=us-east-1
export COGNITO_ISSUER_URI=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_XXXXXXXXX
export COGNITO_JWK_URI=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_XXXXXXXXX/.well-known/jwks.json
