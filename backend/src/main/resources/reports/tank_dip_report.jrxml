              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="tank_dip_report"
              pageWidth="842" pageHeight="595"
              orientation="Landscape"
              columnWidth="822" leftMargin="10" rightMargin="10" topMargin="10" bottomMargin="10"
              uuid="b1c2d3e4-f5a6-7b8c-9d0e-1f2a3b4c5d6e">

    <!-- Parameters -->
    <parameter name="companyName" class="java.lang.String"/>
    <parameter name="companyAddress" class="java.lang.String"/>
    <parameter name="companyPhone" class="java.lang.String"/>
    <parameter name="reportTitle" class="java.lang.String"/>
