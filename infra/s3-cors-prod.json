{
  "CORSRules": [
    {
      "AllowedOrigins": [
        "https://stopforfuel.com",
        "https://app.stopforfuel.com"
      ],
      "AllowedMethods": ["GET", "HEAD"],
      "AllowedHeaders": ["*"],
      "ExposeHeaders": [
        "Content-Disposition",
        "Content-Length",
        "Content-Type",
        "ETag",
        "Accept-Ranges"
      ],
      "MaxAgeSeconds": 3000
    }
  ]
}
